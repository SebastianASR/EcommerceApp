@model EcommerceApp.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="container py-5 z-auth-shell">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border rounded-4 text-white p-4 z-auth-card">
                <div class="card-body text-start">

                    <div class="text-center mb-4">
                        <div class="z-auth-icon mb-3">
                            <i class="fa-solid fa-key fs-3"></i>
                        </div>

                        <h3 class="fw-black z-auth-title mb-1">
                            RECUPERAR ACCESO
                        </h3>

                        <p class="z-auth-subtitle small mb-0">
                            Ingresa tu correo y enviaremos un enlace seguro para cambiar tu contraseña.
                        </p>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label small fw-bold z-auth-label">
                                CORREO ELECTRÓNICO
                            </label>

                            <input asp-for="Email"
                                   type="email"
                                   class="form-control rounded-3 py-2 z-auth-input"
                                   placeholder="ejemplo@zcommerce.cl" />

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn z-auth-primary-btn w-100 fw-bold py-2 rounded-3 shadow-sm mb-3">
                            Enviar enlace de recuperación
                            <i class="fa-solid fa-paper-plane ms-1"></i>
                        </button>
                    </form>

                    <div class="text-center pt-3 border-top border-secondary border-opacity-25 mt-3">
                        <p class="mb-0 small z-auth-subtitle">
                            ¿Recordaste tu contraseña?
                            <a asp-action="Login"
                               class="z-auth-link text-decoration-none fw-bold">
                                Volver al login
                            </a>
                        </p>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}