@{
    ViewData["Title"] = "Revisa tu correo";
}

<div class="container py-5 z-auth-shell">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow-lg border rounded-4 text-white p-4 z-auth-card">
                <div class="card-body text-center p-4">

                    <div class="z-auth-icon mb-4">
                        <i class="fa-solid fa-paper-plane fs-3"></i>
                    </div>

                    <h3 class="fw-black z-auth-title mb-2">
                        REVISA TU CORREO
                    </h3>

                    <p class="z-auth-subtitle mb-4">
                        Si el correo existe en nuestro sistema, recibirás un enlace seguro para restablecer tu contraseña.
                    </p>

                    <div class="alert z-auth-info rounded-4 small text-start mb-4">
                        <i class="fa-solid fa-shield-halved me-1 text-primary"></i>
                        Por seguridad, no confirmamos si el correo está registrado o no. Revisa tu bandeja de entrada, spam o promociones.
                    </div>

                    <a asp-controller="Account"
                       asp-action="Login"
                       class="btn z-auth-primary-btn fw-bold rounded-3 px-4 py-2">
                        <i class="fa-solid fa-arrow-left me-1"></i>
                        Volver al login
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>