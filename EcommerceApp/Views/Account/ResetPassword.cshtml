@model EcommerceApp.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Nueva contraseña";
}

<div class="container py-5 z-auth-shell">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border rounded-4 text-white p-4 z-auth-card">
                <div class="card-body text-start">

                    <div class="text-center mb-4">
                        <div class="z-auth-icon mb-3">
                            <i class="fa-solid fa-lock-open fs-3"></i>
                        </div>

                        <h3 class="fw-black z-auth-title mb-1">
                            NUEVA CONTRASEÑA
                        </h3>

                        <p class="z-auth-subtitle small mb-0">
                            Crea una nueva contraseña segura para recuperar el acceso a tu cuenta.
                        </p>
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Token" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label small fw-bold z-auth-label">
                                NUEVA CONTRASEÑA
                            </label>

                            <input asp-for="Password"
                                   type="password"
                                   class="form-control rounded-3 py-2 z-auth-input"
                                   placeholder="••••••••" />

                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label small fw-bold z-auth-label">
                                CONFIRMAR CONTRASEÑA
                            </label>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control rounded-3 py-2 z-auth-input"
                                   placeholder="••••••••" />

                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn z-auth-primary-btn w-100 fw-bold py-2 rounded-3 shadow-sm">
                            Guardar nueva contraseña
                            <i class="fa-solid fa-floppy-disk ms-1"></i>
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}