@model EcommerceApp.Models.Pedido

@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="container py-5 text-start">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="text-center mb-5">
                <i class="fa-solid fa-circle-check text-success display-3 mb-3"></i>
                <h2 class="fw-black text-dark mb-1">¡Transacción Exitosa!</h2>
                <p class="text-muted">Tu orden de hardware ha sido procesada y registrada correctamente.</p>

                <div class="d-flex justify-content-center gap-2 flex-wrap mt-3">
                    <span class="badge bg-dark px-3 py-2 font-monospace">ORDEN_ID: #@Model.Id</span>
                    <span class="badge bg-success px-3 py-2">Pago: @Model.EstadoPago</span>
                    <span class="badge bg-primary px-3 py-2">@Model.TipoCliente</span>
                </div>
            </div>

            <div class="card shadow-sm border rounded-4 p-4 bg-white mb-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 border-bottom pb-3 mb-4">
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">
                            <i class="fa-solid fa-receipt text-muted me-2"></i>Comprobante de Despacho
                        </h5>
                        <p class="text-muted small mb-0">
                            Fecha de compra: @Model.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>

                    <span class="badge bg-dark px-3 py-2">@Model.EstadoPedido</span>
                </div>

                <div class="row g-3 mb-4 text-muted small">
                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100 bg-light">
                            <strong class="text-dark d-block mb-2">
                                <i class="fa-solid fa-user me-1"></i> RECEPTOR
                            </strong>
                            @Model.NombreCompleto <br />
                            @Model.Correo <br />
                            @Model.Telefono
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="border rounded-4 p-3 h-100 bg-light">
                            <strong class="text-dark d-block mb-2">
                                <i class="fa-solid fa-location-dot me-1"></i> DESTINO DE DESPACHO
                            </strong>
                            Calle @Model.Calle #@Model.Numero <br />

                            @if (!string.IsNullOrWhiteSpace(Model.DeptoBlockOficina))
                            {
                                @Model.DeptoBlockOficina <br />
                            }

                            @Model.Comuna, @Model.Region
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ComentarioCliente))
                {
                    <div class="alert alert-light border rounded-4 small text-muted mb-4">
                        <strong class="text-dark d-block mb-1">
                            <i class="fa-solid fa-message me-1"></i> Comentario del cliente
                        </strong>
                        @Model.ComentarioCliente
                    </div>
                }

                <h6 class="fw-bold text-dark mb-3">Artículos Adquiridos</h6>

                <div class="table-responsive border rounded-3 mb-3">
                    <table class="table table-hover align-middle mb-0 small text-start">
                        <thead class="bg-light">
                            <tr>
                                <th class="py-2 ps-3">Componente</th>
                                <th class="py-2 text-center">Cantidad</th>
                                <th class="py-2 text-end">Precio Unitario</th>
                                <th class="py-2 text-end pe-3">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var det in Model.Detalles)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-dark">@det.Producto.Nombre</td>
                                    <td class="text-center text-muted">x@(det.Cantidad)</td>
                                    <td class="text-end text-muted">$ @det.PrecioUnitario.ToString("N0")</td>
                                    <td class="text-end pe-3 fw-semibold text-dark">
                                        $ @((det.PrecioUnitario * det.Cantidad).ToString("N0"))
                                    </td>
                                </tr>
                            }

                            <tr class="table-active fw-bold">
                                <td colspan="3" class="ps-3 text-dark">TOTAL FACTURADO:</td>
                                <td class="text-end pe-3 text-primary fs-5">$ @Model.Total.ToString("N0")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-success border-0 rounded-4 small mb-0">
                    <i class="fa-solid fa-shield-halved me-1"></i>
                    Pago autorizado mediante Webpay Plus Sandbox. Este comprobante corresponde al flujo simulado del proyecto.
                </div>
            </div>

            <div class="text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark fw-bold px-4 py-2 rounded-3">
                    <i class="fa-solid fa-house me-2"></i> Volver al Inicio
                </a>
            </div>
        </div>
    </div>
</div>