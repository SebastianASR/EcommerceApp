@using System.Text.Json
@model EcommerceApp.Models.VentasDashboardViewModel

@{
    ViewData["Title"] = "Dashboard de Ventas";

    bool esDemoAdmin = ViewBag.EsDemoAdmin == true;

    string Json(object data)
    {
        return JsonSerializer.Serialize(data);
    }
}

<div class="container py-5 text-start">

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 fw-bold">
                ANALYTICS ADMINISTRATIVO
            </span>

            <h2 class="fw-black mb-1 mt-2">
                <i class="fa-solid fa-chart-line text-success me-2"></i>Dashboard de Ventas
            </h2>

            <p class="text-muted mb-0">
                Métricas comerciales, comportamiento de pedidos y productos más vendidos.
            </p>
        </div>

        <div>
            @await Html.PartialAsync("_AdminPanelNav")
        </div>
    </div>

    @if (esDemoAdmin)
    {
        <div class="alert alert-warning border-0 rounded-4 shadow-sm mb-4">
            <div class="fw-bold">
                <i class="fa-solid fa-user-shield me-1"></i> Modo DemoAdmin activo
            </div>
            <div class="small">
                Puedes visualizar las métricas del sistema, pero las acciones críticas siguen bloqueadas.
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">VENTAS TOTALES</p>
                        <h3 class="fw-black mb-0">$ @Model.VentasTotales.ToString("N0")</h3>
                    </div>

                    <div class="bg-success bg-opacity-10 text-success rounded-4 p-3">
                        <i class="fa-solid fa-sack-dollar fs-4"></i>
                    </div>
                </div>

                <div class="small text-muted mt-3">
                    Solo pedidos con pago autorizado.
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">PEDIDOS</p>
                        <h3 class="fw-black mb-0">@Model.TotalPedidos</h3>
                    </div>

                    <div class="bg-primary bg-opacity-10 text-primary rounded-4 p-3">
                        <i class="fa-solid fa-receipt fs-4"></i>
                    </div>
                </div>

                <div class="small text-muted mt-3">
                    @Model.PedidosAutorizados autorizado(s).
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">TICKET PROMEDIO</p>
                        <h3 class="fw-black mb-0">$ @Model.TicketPromedio.ToString("N0")</h3>
                    </div>

                    <div class="bg-info bg-opacity-10 text-info rounded-4 p-3">
                        <i class="fa-solid fa-chart-simple fs-4"></i>
                    </div>
                </div>

                <div class="small text-muted mt-3">
                    Promedio por compra autorizada.
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted small fw-bold mb-1">CLIENTES ÚNICOS</p>
                        <h3 class="fw-black mb-0">@Model.ClientesUnicos</h3>
                    </div>

                    <div class="bg-dark bg-opacity-10 text-dark rounded-4 p-3">
                        <i class="fa-solid fa-users fs-4"></i>
                    </div>
                </div>

                <div class="small text-muted mt-3">
                    Según correo registrado en pedidos.
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <p class="text-muted small fw-bold mb-1">VENTAS HOY</p>
                <h4 class="fw-black text-success mb-0">$ @Model.VentasHoy.ToString("N0")</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <p class="text-muted small fw-bold mb-1">VENTAS DEL MES</p>
                <h4 class="fw-black text-primary mb-0">$ @Model.VentasMesActual.ToString("N0")</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <p class="text-muted small fw-bold mb-1">PRODUCTOS VENDIDOS</p>
                <h4 class="fw-black text-dark mb-0">@Model.ProductosVendidos</h4>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <p class="text-muted small fw-bold mb-1">PEDIDOS EN PROCESO</p>
                <h4 class="fw-black text-warning mb-0">@Model.PedidosPendientes</h4>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h5 class="fw-black mb-1">
                                <i class="fa-solid fa-chart-line text-success me-2"></i>
                                Ventas últimos 7 días
                            </h5>
                            <p class="text-muted small mb-0">
                                Total vendido por día considerando pagos autorizados.
                            </p>
                        </div>

                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                            Diario
                        </span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <canvas id="ventas7DiasChart" height="130"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h5 class="fw-black mb-1">
                                <i class="fa-solid fa-calendar-days text-primary me-2"></i>
                                Ventas últimos 6 meses
                            </h5>
                            <p class="text-muted small mb-0">
                                Evolución mensual del sistema.
                            </p>
                        </div>

                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                            Mensual
                        </span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <canvas id="ventas6MesesChart" height="180"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <h5 class="fw-black mb-1">
                        <i class="fa-solid fa-ranking-star text-warning me-2"></i>
                        Top productos más vendidos
                    </h5>
                    <p class="text-muted small mb-0">
                        Ranking por cantidad vendida.
                    </p>
                </div>

                <div class="card-body p-4">
                    @if (!Model.ProductosMasVendidos.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fa-solid fa-box-open display-6 opacity-50 mb-3"></i>
                            <p class="mb-0">Aún no hay productos vendidos.</p>
                        </div>
                    }
                    else
                    {
                        var maxCantidad = Model.ProductosMasVendidos.Max(p => p.CantidadVendida);

                        foreach (var producto in Model.ProductosMasVendidos)
                        {
                            var porcentaje = maxCantidad > 0
                            ? (producto.CantidadVendida * 100 / maxCantidad)
                            : 0;

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <div class="fw-bold text-dark">
                                            @producto.Nombre
                                        </div>
                                        <div class="small text-muted">
                                            $ @producto.TotalVendido.ToString("N0") vendidos
                                        </div>
                                    </div>

                                    <span class="badge bg-warning text-dark px-3 py-2">
                                        @producto.CantidadVendida u.
                                    </span>
                                </div>

                                <div class="progress rounded-pill" style="height: 9px;">
                                    <div class="progress-bar bg-warning"
                                         role="progressbar"
                                         style="width: @porcentaje%;"
                                         aria-valuenow="@porcentaje"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <h5 class="fw-black mb-1">
                        <i class="fa-solid fa-list-check text-info me-2"></i>
                        Estados de pedidos
                    </h5>
                    <p class="text-muted small mb-0">
                        Distribución actual del estado operativo.
                    </p>
                </div>

                <div class="card-body p-4">
                    @if (!Model.EstadosPedidos.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fa-solid fa-clipboard-list display-6 opacity-50 mb-3"></i>
                            <p class="mb-0">Aún no hay estados registrados.</p>
                        </div>
                    }
                    else
                    {
                        var totalEstados = Model.EstadosPedidos.Sum(e => e.Cantidad);

                        foreach (var estado in Model.EstadosPedidos)
                        {
                            var porcentaje = totalEstados > 0
                            ? (estado.Cantidad * 100 / totalEstados)
                            : 0;

                            string badgeClass = estado.Estado switch
                            {
                                "Pagado" => "bg-primary",
                                "Preparando" => "bg-info text-dark",
                                "Enviado" => "bg-warning text-dark",
                                "Entregado" => "bg-success",
                                "Cancelado" => "bg-danger",
                                "Pendiente" => "bg-secondary",
                                _ => "bg-dark"
                            };

                            <div class="mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge @badgeClass px-3 py-2">
                                        @estado.Estado
                                    </span>

                                    <span class="fw-bold text-dark">
                                        @estado.Cantidad pedido(s)
                                    </span>
                                </div>

                                <div class="progress rounded-pill" style="height: 9px;">
                                    <div class="progress-bar @badgeClass"
                                         role="progressbar"
                                         style="width: @porcentaje%;"
                                         aria-valuenow="@porcentaje"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="card-header bg-white border-0 p-4">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h5 class="fw-black mb-1">
                        <i class="fa-solid fa-clock-rotate-left text-primary me-2"></i>
                        Últimos pedidos
                    </h5>
                    <p class="text-muted small mb-0">
                        Actividad reciente registrada en la tienda.
                    </p>
                </div>

                <a asp-controller="Pedidos"
                   asp-action="AdminCompras"
                   class="btn btn-outline-primary fw-bold rounded-3">
                    <i class="fa-solid fa-receipt me-1"></i>
                    Ver todas las compras
                </a>
            </div>
        </div>

        @if (!Model.UltimosPedidos.Any())
        {
            <div class="card-body text-center text-muted py-5">
                <i class="fa-solid fa-receipt display-6 opacity-50 mb-3"></i>
                <p class="mb-0">Aún no hay pedidos registrados.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Pedido</th>
                            <th class="py-3">Cliente</th>
                            <th class="py-3">Fecha</th>
                            <th class="py-3">Pago</th>
                            <th class="py-3">Estado</th>
                            <th class="py-3 text-end">Total</th>
                            <th class="py-3 text-end pe-4">Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var pedido in Model.UltimosPedidos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">
                                        #@pedido.Id
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(pedido.BuyOrder))
                                    {
                                        <small class="text-muted font-monospace">
                                            @pedido.BuyOrder
                                        </small>
                                    }
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">
                                        @pedido.NombreCompleto
                                    </div>

                                    <small class="text-muted">
                                        @pedido.Correo
                                    </small>
                                </td>

                                <td>
                                    <div class="fw-semibold">
                                        @pedido.FechaPedido.ToLocalTime().ToString("dd/MM/yyyy")
                                    </div>

                                    <small class="text-muted">
                                        @pedido.FechaPedido.ToLocalTime().ToString("HH:mm")
                                    </small>
                                </td>

                                <td>
                                    @if (pedido.EstadoPago == "Autorizado")
                                    {
                                        <span class="badge bg-success px-3 py-2">
                                            <i class="fa-solid fa-circle-check me-1"></i>
                                            Autorizado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2">
                                            @pedido.EstadoPago
                                        </span>
                                    }
                                </td>

                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                                        @pedido.EstadoPedido
                                    </span>
                                </td>

                                <td class="text-end">
                                    <span class="fw-black">
                                        $ @pedido.Total.ToString("N0")
                                    </span>
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-controller="Pedidos"
                                       asp-action="Detalle"
                                       asp-route-id="@pedido.Id"
                                       class="btn btn-sm btn-outline-primary fw-bold rounded-3">
                                        <i class="fa-solid fa-eye me-1"></i>
                                        Detalle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ventas7Dias = @Html.Raw(Json(Model.VentasUltimos7Dias));
        const ventas6Meses = @Html.Raw(Json(Model.VentasUltimos6Meses));

        const formatoCLP = new Intl.NumberFormat("es-CL", {
            style: "currency",
            currency: "CLP",
            maximumFractionDigits: 0
        });

        const ctxVentas7Dias = document.getElementById("ventas7DiasChart");

        if (ctxVentas7Dias) {
            new Chart(ctxVentas7Dias, {
                type: "line",
                data: {
                    labels: ventas7Dias.map(x => x.Dia),
                    datasets: [
                        {
                            label: "Ventas",
                            data: ventas7Dias.map(x => x.Total),
                            tension: 0.35,
                            fill: true,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return "Ventas: " + formatoCLP.format(context.raw);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function (value) {
                                    return formatoCLP.format(value);
                                }
                            }
                        }
                    }
                }
            });
        }

        const ctxVentas6Meses = document.getElementById("ventas6MesesChart");

        if (ctxVentas6Meses) {
            new Chart(ctxVentas6Meses, {
                type: "bar",
                data: {
                    labels: ventas6Meses.map(x => x.Mes),
                    datasets: [
                        {
                            label: "Ventas",
                            data: ventas6Meses.map(x => x.Total),
                            borderWidth: 2,
                            borderRadius: 10
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return "Ventas: " + formatoCLP.format(context.raw);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function (value) {
                                    return formatoCLP.format(value);
                                }
                            }
                        }
                    }
                }
            });
        }
    </script>
}